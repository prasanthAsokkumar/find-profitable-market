# PostgreSQL (native pg env vars)
PGHOST=localhost
PGPORT=5432
PGUSER=your_user
PGPASSWORD=your_password
PGDATABASE=your_database

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Polymarket
POLYMARKET_API_URL=https://clob.polymarket.com

# Price range (percentage)
PRICE_MIN=70
PRICE_MAX=97

# Dip-buy feature (Telegram-initiated cheap-price buys)
# Telegram commands: /dipbuy <event_slug> <market_slug> YES|NO [max_usd]
# These fire LIVE regardless of TRADE_ENABLED.
DIP_THRESHOLD_CENTS=5
DIP_MAX_USD=50
DIP_POLL_SECONDS=30
